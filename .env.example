# ============================================================
# iso27001-mcp — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ── Required: Authentication ─────────────────────────────────
# 32-byte hex secret used to HMAC-sign API keys.
# Generate with: openssl rand -hex 32
# MUST be exactly 64 hex chars — the server refuses to start otherwise
HMAC_SECRET=

# ── Required: Database ───────────────────────────────────────
# Path to the encrypted SQLite database file.
DB_PATH=./isms.db

# 64-character hex key for AES-256 SQLCipher encryption.
# Generate with: openssl rand -hex 32
# MUST be exactly 64 hex chars — the server refuses to start otherwise
DB_ENCRYPTION_KEY=

# ── Optional: Audit Log ──────────────────────────────────────
# Path for the append-only JSON-L audit log flat file.
AUDIT_LOG_PATH=./audit.log

# ── Optional: Server Mode ────────────────────────────────────
# local | team | hosted | ci
MCP_MODE=local

# In-process rate limit (tool calls per minute, all modes).
RATE_LIMIT_RPM=500

# ── Hosted SSE Mode Only ─────────────────────────────────────
PORT=3000

# Set to "true" when running behind nginx/Caddy TLS proxy.
# Auto-defaults to "true" when NODE_ENV=production.
BEHIND_TLS_PROXY=false

# SSE session time-to-live in hours.
SESSION_TTL_HOURS=4

# ── Optional: Jira Integration ───────────────────────────────
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=SEC

# ── Optional: GitHub Integration ─────────────────────────────
# GITHUB_TOKEN=ghp_your_personal_access_token
# GITHUB_REPO=your-org/your-repo

# ── Build / CI ───────────────────────────────────────────────
NODE_ENV=development
# GIT_COMMIT_SHA=  # Injected automatically by CI
